# upload-orchestrator — variáveis de ambiente
# Copie para .env e preencha os valores obrigatórios

PORT=8081

# PostgreSQL
POSTGRES_DB=orchestrator
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=

# MinIO (console disponível em localhost:9011)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=diagrams

# RabbitMQ (painel disponível em localhost:15672)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=

# Filas e tópicos
PROCESS_QUEUE=process.queue
PROCESSING_TOPIC=processing.topic
REPORT_TOPIC=report.topic
